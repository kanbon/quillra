# =============================================================================
# Quillra — production / VPS (.env lives beside the running API, e.g. packages/api/.env)
# =============================================================================

# --- Public URL of this API (no trailing slash) ---
# Must match how users open the app in the browser (same host as the SPA if you serve it from Node).
BETTER_AUTH_URL=https://cms.example.com

# --- Browser origins allowed to send cookies (comma-separated, no spaces) ---
# Include your real site URL. If API + SPA are the same origin, this matches BETTER_AUTH_URL.
TRUSTED_ORIGINS=https://cms.example.com

BETTER_AUTH_SECRET=
# Generate once: openssl rand -base64 32

# --- Anthropic (Claude Agent SDK runs on the server) ---
ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-20250514

# --- GitHub OAuth (Sign in with GitHub) ---
# GitHub → Settings → Developer settings → OAuth Apps → New:
#   Homepage URL:    https://cms.example.com
#   Callback URL:    https://cms.example.com/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Live dev preview (iframe in the editor) ---
# Subdomain mode: each preview gets {id}.PREVIEW_DOMAIN (e.g. abc123.cms.example.com)
# Requires wildcard DNS: *.cms.example.com → your VPS IP (DNS only, not Cloudflare-proxied)
# Caddy handles TLS automatically via on-demand certificates.
PREVIEW_DOMAIN=cms.example.com
# PREVIEW_PORT_BASE=4321

# --- Paths (defaults are fine for Docker: volume mounted at packages/api/data) ---
DATABASE_URL=file:./data/cms.sqlite
WORKSPACE_DIR=./data/workspaces
PORT=3000

# --- GitHub App (optional, for server-side clone of private repos) ---
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_APP_CLIENT_ID=
# GITHUB_APP_CLIENT_SECRET=

# =============================================================================
# Email (invitations, magic-link client login)
# =============================================================================
# Pluggable backend. Pick one:
#   none    — sending disabled. Invites become shareable links you copy/paste
#             to the recipient yourself. Default — works out of the box for
#             solo evaluators.
#   resend  — Resend.com REST API. Set RESEND_API_KEY below. Easiest cloud option.
#   smtp    — Universal SMTP (Gmail, Postfix, AWS SES, Mailgun, Postmark, etc.).
#             Coming in a follow-up release.
EMAIL_PROVIDER=none

# Display name + address used in the From header on every email Quillra sends.
# For Resend, the domain must be verified in your Resend dashboard.
EMAIL_FROM=Quillra <hello@quillra.com>

# --- Resend backend (when EMAIL_PROVIDER=resend) ---
# Get a key at https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# --- SMTP backend (placeholder — not yet implemented) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_SECURE=true
