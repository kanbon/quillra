# =============================================================================
# Quillra — production / VPS (.env lives beside the running API, e.g. packages/api/.env)
# =============================================================================

# --- Public URL of this API (no trailing slash) ---
# Must match how users open the app in the browser (same host as the SPA if you serve it from Node).
BETTER_AUTH_URL=https://cms.example.com

# --- Browser origins allowed to send cookies (comma-separated, no spaces) ---
# Include your real site URL. If API + SPA are the same origin, this matches BETTER_AUTH_URL.
TRUSTED_ORIGINS=https://cms.example.com

BETTER_AUTH_SECRET=
# Generate once: openssl rand -base64 32

# --- Anthropic (Claude Agent SDK runs on the server) ---
ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-20250514

# --- GitHub OAuth (Sign in with GitHub) ---
# GitHub → Settings → Developer settings → OAuth Apps → New:
#   Homepage URL:    https://cms.example.com
#   Callback URL:    https://cms.example.com/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- GitHub: clone, fetch, push for connected repos ---
# Classic PAT: repo scope (private repos) or public_repo only for public.
# Fine-grained: Contents read/write on the repos you use.
GITHUB_TOKEN=

# --- Live dev preview (iframe in the editor) ---
# Dev servers speak HTTP. The browser opens: http://PREVIEW_PUBLIC_HOST:PORT
# Use your VPS public hostname or IP. Open TCP PREVIEW_PORT_BASE … PREVIEW_PORT_BASE+1999 in the firewall.
#
# If the CMS is served over HTTPS, browsers may block http://… preview URLs (mixed content). Mitigations:
# access the CMS over HTTP on a trusted network, Tailscale, or SSH port-forward; or terminate TLS for
# preview ports behind your own proxy (advanced).
PREVIEW_PUBLIC_HOST=cms.example.com
PREVIEW_PUBLIC_PROTO=http
# PREVIEW_PORT_BASE=4321

# --- Paths (defaults are fine for Docker: volume mounted at packages/api/data) ---
DATABASE_URL=file:./data/cms.sqlite
WORKSPACE_DIR=./data/workspaces
PORT=3000

# --- GitHub App (optional; not required when using GITHUB_TOKEN) ---
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_APP_CLIENT_ID=
# GITHUB_APP_CLIENT_SECRET=
