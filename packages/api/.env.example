# =============================================================================
# Quillra — production / VPS (.env lives beside the running API, e.g. packages/api/.env)
# =============================================================================

# --- Public URL of this API (no trailing slash) ---
# Must match how users open the app in the browser (same host as the SPA if you serve it from Node).
BETTER_AUTH_URL=https://cms.example.com

# --- Browser origins allowed to send cookies (comma-separated, no spaces) ---
# Include your real site URL. If API + SPA are the same origin, this matches BETTER_AUTH_URL.
TRUSTED_ORIGINS=https://cms.example.com

BETTER_AUTH_SECRET=
# Production: generate once with `openssl rand -base64 32` and set explicitly here.
# Local dev: leave blank. On first boot the API generates 32 random bytes and
# writes them to data/.boot-secret (mode 0600, gitignored). Subsequent boots
# read it back. Production should still set this in the environment so the
# secret lives outside the data volume.

# --- Encryption for API keys and other secrets stored in SQLite ---
# Generate once with `openssl rand -hex 32`. Keep this value stable and backed
# up alongside the database; changing or losing it makes stored secrets unreadable.
QUILLRA_ENCRYPTION_KEY=

# --- First-run and no-email recovery access ---
# Recommended: generate once with `openssl rand -base64 24`. The browser asks
# for this before it can change setup or reveal an on-screen login code.
# Leave blank to derive an installation-specific token from BETTER_AUTH_SECRET;
# the generated value is printed only to the Quillra server logs.
QUILLRA_SETUP_TOKEN=

# --- Anthropic (Claude Agent SDK runs on the server) ---
ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-20250514

# --- Optional GitHub OAuth (reserved for linking a personal GitHub account) ---
# Owner and team sign-in use passwordless email codes. The setup wizard creates
# the GitHub App used for repository access, so these can normally stay unset.
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# --- Live dev preview (iframe in the editor) ---
# Required for framework-transparent production previews. Each project gets an
# opaque child host such as p-abc123.preview.example.com, while its dev server
# stays private on loopback. A same-site sibling/subdomain of BETTER_AUTH_URL
# has the broadest browser-cookie compatibility. Create wildcard DNS and use
# the included Caddy block.
# Localhost automatically uses *.localhost and needs no setting.
PREVIEW_DOMAIN=preview.example.com
# Keep the workspace port range private; it does not need firewall exposure.
# PREVIEW_PORT_BASE=4321

# --- Paths (defaults are fine for Docker: volume mounted at packages/api/data) ---
DATABASE_URL=file:./data/cms.sqlite
WORKSPACE_DIR=./data/workspaces
PORT=3000

# --- GitHub App (optional, for server-side clone of private repos) ---
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_APP_CLIENT_ID=
# GITHUB_APP_CLIENT_SECRET=

# =============================================================================
# Email (invitations, magic-link client login)
# =============================================================================
# Pluggable backend. Pick one:
#   none    — sending disabled. Default for solo evaluation; owner sign-in
#             uses the server access token. Configure email before inviting
#             team members or clients.
#   resend  — Resend.com REST API. Set RESEND_API_KEY below. Easiest cloud option.
#   smtp    — Universal SMTP (Gmail, Postfix, AWS SES, Mailgun, Postmark, etc.).
EMAIL_PROVIDER=none

# Display name + address used in the From header on every email Quillra sends.
# For Resend, the domain must be verified in your Resend dashboard.
EMAIL_FROM=Quillra <hello@example.com>

# --- Resend backend (when EMAIL_PROVIDER=resend) ---
# Get a key at https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# --- SMTP backend (when EMAIL_PROVIDER=smtp) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_SECURE=false
# Use SMTP_SECURE=true for implicit TLS on port 465. Keep it false for
# STARTTLS, including the common submission port 587.
