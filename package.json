{
  "name": "quillra",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=22.13.0"
  },
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "db:push": "turbo run db:push --filter=@quillra/api",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run build && playwright test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check:em-dashes": "node scripts/check-em-dashes.mjs",
    "check": "turbo run typecheck && biome check . && node scripts/check-em-dashes.mjs && turbo run test"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@playwright/test": "1.61.1",
    "@vitest/ui": "3.2.7",
    "turbo": "2.8.20",
    "typescript": "~5.7.3",
    "vitest": "3.2.7"
  },
  "packageManager": "pnpm@10.34.0"
}
